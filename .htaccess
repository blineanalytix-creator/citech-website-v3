# ============================================
# CITECH AI - Security & Performance Configuration
# Version: 3.0
# ============================================

# ============================================
# HTTPS + WWW Redirect (kombiniert, keine Chain)
# ============================================
RewriteEngine On

RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteCond %{HTTP_HOST} ^(www\.)?citech-ai\.de$ [NC]
RewriteRule ^(.*)$ https://www.citech-ai.de/$1 [L,R=301]

# ============================================
# Security Headers
# ============================================
<IfModule mod_headers.c>
    # HSTS (1 Jahr, inkl. Subdomains)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Verhindert MIME-Type-Sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Clickjacking-Schutz
    Header always set X-Frame-Options "SAMEORIGIN"

    # XSS-Filter
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer-Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://www.google.com https://maps.google.com https://maps.googleapis.com; font-src 'self'; frame-src https://www.google.com https://maps.google.com; connect-src 'self'; base-uri 'self'; form-action 'self' https://newsletter.citech-ai.de"

    # Cache: Statische Assets (1 Jahr, immutable)
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|woff|woff2|ttf|ico|pdf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Cache: CSS/JS (1 Tag, mit Versionierung ?v=X)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=86400, must-revalidate"
    </FilesMatch>

    # Cache: HTML (kein Cache)
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Sitemap als XML
    <FilesMatch "sitemap\.xml$">
        Header set Content-Type "application/xml; charset=UTF-8"
    </FilesMatch>
</IfModule>

# ============================================
# Verzeichnislisting deaktivieren
# ============================================
Options -Indexes

# ============================================
# Sensible Dateien schuetzen
# ============================================
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "(\.htaccess|\.htpasswd|\.ini|\.log|\.sh|\.sql|\.env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "(package\.json|package-lock\.json|composer\.json|composer\.lock|PROJECT_DOCS\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ============================================
# PHP Sicherheit
# ============================================
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value session.cookie_httponly 1
    php_value session.cookie_secure 1
    php_value session.use_strict_mode 1
    php_value upload_max_filesize 2M
    php_value post_max_size 8M
    php_value max_execution_time 30
</IfModule>

# ============================================
# Komprimierung (GZIP/Deflate)
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE application/xml
</IfModule>

# ============================================
# MIME-Types
# ============================================
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType image/svg+xml .svg
    AddType font/woff .woff
    AddType font/woff2 .woff2
    AddType font/ttf .ttf
    AddType application/xml .xml
    AddType application/json .json
    AddDefaultCharset UTF-8
</IfModule>

# ============================================
# Fehlerseiten
# ============================================
ErrorDocument 403 /pages/404.html
ErrorDocument 404 /pages/404.html
ErrorDocument 500 /pages/404.html

# ============================================
# Bot-Schutz
# ============================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Leere User-Agents + bekannte boesartige Bots
    RewriteCond %{HTTP_USER_AGENT} ^$ [OR]
    RewriteCond %{HTTP_USER_AGENT} (libwww-perl|nikto|sqlmap|nmap) [NC]
    RewriteRule .* - [F,L]

    # Aggressive SEO-Bots (optional)
    # RewriteCond %{HTTP_USER_AGENT} (ahrefs|semrush|mj12bot|dotbot) [NC]
    # RewriteRule .* - [F,L]

    # ============================================
    # SEO-Dateien direkt ausliefern
    # ============================================
    RewriteRule ^sitemap\.xml$ - [L]
    RewriteRule ^robots\.txt$ - [L]

    # ============================================
    # Saubere URLs ohne .html
    # /pages/kontakt statt /pages/kontakt.html
    # ============================================

    # Intern: .html anfuegen wenn Datei existiert
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]

    # Extern: .html Aufrufe zu sauberer URL redirecten (301)
    RewriteCond %{THE_REQUEST} \s/(.+?)\.html[\s?] [NC]
    RewriteCond %{REQUEST_URI} !^/index\.html$
    RewriteRule ^ /%1 [R=301,L]
</IfModule>
